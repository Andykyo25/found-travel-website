# Railway 後台登入。密碼與 session secret 只放在 Railway Variables，
# 不要寫進 GitHub。
STUDIO_ADMIN_EMAIL=tgfc069@gmail.com
STUDIO_ADMIN_PASSWORD=

# 可選。若未填，系統會安全地從後台密碼衍生 session 簽章。
STUDIO_SESSION_SECRET=

# Railway Storage Bucket 連線資訊。可使用 Bucket 的 Auto-inject，
# 或在網站服務的 Variables 中引用 Bucket credentials。
BUCKET_NAME=
BUCKET_ENDPOINT=
BUCKET_ACCESS_KEY_ID=
BUCKET_SECRET_ACCESS_KEY=
BUCKET_REGION=auto
